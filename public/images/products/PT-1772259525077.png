        <script defer>

            $(function(){

                $.ajaxSetup({

                    beforeSend: function(xhr, settings) {

                        if (settings.data.indexOf('csrf_test_name') === -1) {

                            settings.data += '&csrf_test_name=' + encodeURIComponent(getCookie('csrf_cookie_name'));

                        }

                    }

                });

                let runSlick = false, tabId, widgetId , data_item = [], pr_display = 1;

                let pr_config_style_8 = {

                    infinite: true,

                    dots:false,

                    autoplay: true,

                    autoplaySpeed: 3000,

                    speed: 700,

                    slidesToShow: 4,

                    slidesToScroll: 4,

                    responsive: [

                        { breakpoint: 1000, settings: { slidesToShow: 3, slidesToScroll: 3, } },

                        { breakpoint: 600, settings: { slidesToShow: 2, slidesToScroll: 2, } }

                    ]

                };

                function product_style_8_slider(id, config) {

                    if(pr_display === 1) return false;

                    let productList     = $('#product_style_8_content_' + id);

                    let productBtnNext  = $('#widget_product_btn_next_' + id);

                    let productBtnPrev  = $('#widget_product_btn_prev_' + id);

                    productList.slick(config);

                    productBtnNext.click(function() {productList.slick('slickNext');return false;});

                    productBtnPrev.click(function() {productList.slick('slickPrev');return false;});

                    runSlick = true;

                }

                function product_style_8_slider_load(tabId, widgetId, config) {


                    let product_style_8_content = $('#product_style_8_content_' + widgetId);

                    let product_style_8_link = $('#product_style_8_morelink_' + widgetId+' a.more-link');

                    let loading = $('#widget_product_content_' + widgetId + ' .wg-loading');

                    if(runSlick === true) product_style_8_content.slick('unslick');

                    product_style_8_content.html('');
                    loading.show();

                    if (typeof data_item[tabId] != 'undefined') {

                        product_style_8_content.html(data_item[tabId].item);

                        product_style_8_link.attr('href', data_item[tabId].url);

                        loading.hide();

                        product_style_8_slider(widgetId, config);

                        return false;

                    }

                    else {

                        let data = {

                            action  : 'widget_product_style_8::loadProduct',

                            widgetId   : widgetId,

                            tabId : tabId,

                        };



                        $.post( ajax , data, function() {}, 'json').done(function(response) {

                            loading.hide();

                            if(response.status === 'success') {

                                product_style_8_content.html(response.item);

                                product_style_8_link.attr('href', response.slug);

                                data_item[tabId] = {

                                    item : response.item,

                                    url  : response.slug

                                };

                                product_style_8_slider(widgetId, config);

                            }

                        });

                    }

                }


                product_style_8_slider_load('tab1-16','16', pr_config_style_8);

                

                $(document).on('click', '#product_style_8_header_16 .product_style_8_category_list li.item a', function(){
                    tabId = $(this).attr('data-id');

                    widgetId 	= $(this).attr('data-wg');

                    $('#product_style_8_header_' + widgetId +' .product_style_8_category_list li.item a').removeClass('active');

                    $(this).addClass('active');

                    product_style_8_slider_load(tabId, widgetId, pr_config_style_8);

                    return false;

                });

                $('#product_style_8_header_16 .js_btn_show_tab').click(function() {

                    $(this).closest('.product_style_8_header_left').find('.product_style_8_category_list').toggle();

                    return false;

                });

            });

        </script>

        
                

            </div>

        </div>

