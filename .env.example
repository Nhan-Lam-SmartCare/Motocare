# ============================================
# Environment variables for Motocare (Vite)
# ============================================
# Copy this file to `.env` (local) or set the variables in your hosting provider (Vercel/Netlify).
# NEVER commit .env files with real credentials to git!
# ============================================

# Supabase project V1 — Production (REQUIRED)
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://YOUR-PROJECT-NAME.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY

# Service role key V1 - ONLY for server-side scripts, NEVER expose in frontend!
SUPABASE_URL=https://YOUR-PROJECT-NAME.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ============================================
# Supabase project V2 — Development / Upgrade
# Used by: Proxy switcher (parallel run) + migration scripts
# VITE_ prefix = also bundled into browser build (anon key is safe to expose)
# Non-VITE_ prefix = Node.js scripts only (service role MUST stay server-side)
# ============================================
VITE_SUPABASE_URL_V2=https://yxohjuezxrpnijypkeaa.supabase.co
VITE_SUPABASE_ANON_KEY_V2=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inl4b2hqdWV6eHJwbmlqeXBrZWFhIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQzMjYwNzUsImV4cCI6MjA5OTkwMjA3NX0.XMhY7EAE8JDafRUI6vyFbeL55Yr6PX7wpFQSMjxF4bo
SUPABASE_URL_V2=https://yxohjuezxrpnijypkeaa.supabase.co
# SUPABASE_SERVICE_ROLE_KEY_V2=GET_FROM_SUPABASE_DASHBOARD_V2_SETTINGS_API

# Optional app settings
VITE_APP_NAME=Motocare
VITE_LOG_LEVEL=info

# ============================================
# SECURITY NOTES:
# - ANON_KEY is designed to be public (used with RLS)
# - SERVICE_ROLE_KEY bypasses RLS — NEVER expose it in frontend or commit it
# - Rotate immediately at: https://supabase.com/dashboard/project/<ref>/settings/api
# ============================================
