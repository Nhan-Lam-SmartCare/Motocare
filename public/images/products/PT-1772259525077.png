<script>
  document.addEventListener('DOMContentLoaded', function () {
    const zaloBtns = document.querySelectorAll('.btn-zalo');
    zaloBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        gtag('event', 'click_zalo', {
          'event_category': 'Contact',
          'event_label': 'Click Zalo'
        });
      });
    });

    const orderBtns = document.querySelectorAll('.btn-order');
    orderBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        gtag('event', 'click_order', {
          'event_category': 'Ecommerce',
          'event_label': 'Click đặt hàng'
        });
      });
    });
  });
</script>
