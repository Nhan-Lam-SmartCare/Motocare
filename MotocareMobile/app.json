{
  "expo": {
    "name": "Motocare",
    "slug": "motocare-mobile",
    "version": "1.0.1",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "motocare",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EEF5FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "vn.motocare.mobile"
    },
    "android": {
      "package": "vn.motocare.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#EEF5FF",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "versionCode": 6
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "03a55fcf-40eb-449a-a272-8cde871ac1c5"
      }
    },
    "owner": "nhanxn"
  }
}
