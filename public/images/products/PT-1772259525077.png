</div><script>
  // Năm động
  const yearEl = document.getElementById("currentYear");
  if (yearEl) yearEl.textContent = new Date().getFullYear();

  // Lazy load
  document.addEventListener("DOMContentLoaded", () => {
    const lazyImgs = document.querySelectorAll("img[loading='lazy']");
    lazyImgs.forEach(img => img.onload = () => img.classList.add("loaded"));
  });

  // Zalo target
  const zaloLinks = document.querySelectorAll('a[href*="zalo.me"]');
  zaloLinks.forEach(link => {
    link.setAttribute("target", "_blank");
    link.setAttribute("rel", "noopener");
  });

  // Scroll to top
  const scrollTopBtn = document.getElementById("scrollToTop");
  if (scrollTopBtn) {
    window.addEventListener("scroll", () => {
      scrollTopBtn.style.display = window.scrollY > 300 ? "block" : "none";
    });
    scrollTopBtn.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });
  }

  // SPA Re-track
  window.addEventListener("hashchange", () => {
    if (typeof gtag === "function") {
      gtag("config", "G-1CFSSDHQGY");
    }
  });

  // Confirm load
  document.addEventListener("DOMContentLoaded", () => {
    console.log("✅ Tất cả script & nội dung đã tải xong!");
  });
</script>
<script type="text/javascript">

    $(function(){

        if(typeof $('header').html() != 'undefined') {

            let header = $('header');

            let isHide = false;

            let nav = $('.navigation');

            let nav_p = header.offset();

            $(window).scroll(function () {
                if ($(this).scrollTop() > nav_p.top) {

                    if(!isHide){
                        header.addClass('hideOnScroll');
                        isHide = true;
                        setTimeout(function() { header.removeClass('hideOnScroll') }, 300);
                    }
                    

                    header.addClass('fixed');

                    // nav.addClass('unfixed');

                } else {

                    header.removeClass('fixed');
                    isHide = false;
                    // nav.removeClass('unfixed');

                }

            });


           

        }

    });

</script><script defer type="text/javascript">

    let menu = $('.navigation .menu-left');
    let over2 = $('.over2');
    menu.on('mouseenter',function(){
        $(this).addClass('open');
        over2.addClass('open');
    });
    over2.on('mouseenter',function(){
        $(this).removeClass('open');
        menu.removeClass('open');
    });


    $(function(){

        if(typeof $('.navigation-cate').html() != 'undefined') {

            let navCate = $('.navigation-cate');

            let navCateNoHome = $('.navigation-cate.no-home');

            $(window).scroll(function () {


                if ($(this).scrollTop() > 400 ) {

                    navCate.css({'display': 'block'});

                } else {
                    if(navCateNoHome.length != 0){
                        navCate.css({'display': 'block'});
                    }
                    else{
                        navCate.css({'display': 'none'});

                    }

                }

            });

        }

    });

</script>		</div>
	</body>
</html>